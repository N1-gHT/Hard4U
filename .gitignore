# ============================================================
#  Hard4U — .gitignore
# ============================================================

# ------------------------------------------------------------
# VSCode
# ------------------------------------------------------------
.vscode/
!.vscode/extensions.json   # Exception : partager les extensions recommandées c'est utile

# ------------------------------------------------------------
# Fichiers de sauvegarde & temporaires
# ------------------------------------------------------------
*.bak
*.swp
*.swo
*~
*.tmp
*.patch
*.diff

# ------------------------------------------------------------
# Logs générés par les scripts
# ------------------------------------------------------------
*.log
logs/
audit_report_*.txt
audit_report_*.html
audit_report_*.json
audit_report_*.csv

# ------------------------------------------------------------
# Rapports ShellCheck
# ------------------------------------------------------------
shellcheck_report_*.txt

# ------------------------------------------------------------
# Backup de scripts shell
# ------------------------------------------------------------
*.sh.bak
*.sh.orig

# ------------------------------------------------------------
# Archive / compression
# ------------------------------------------------------------
*.tar.gz
*.zip
*.tar

# ------------------------------------------------------------
# OS
# ------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
.directory

# ------------------------------------------------------------
# Fichiers sensibles — NE JAMAIS committer
# ------------------------------------------------------------
*.pem
*.key
*.crt
*.p12
*.pfx
.env
secrets/
credentials/